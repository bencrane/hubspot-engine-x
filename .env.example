# hubspot-engine-x — Environment Variables
# All secrets managed via Doppler in production. On Railway, set DOPPLER_TOKEN only.

# Supabase Postgres connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/hubspot_engine_x

# Separate secret for super-admin bearer auth (bootstrap operations)
SUPER_ADMIN_JWT_SECRET=your-super-admin-secret-here

# HubSpot app credentials (from developer portal)
HUBSPOT_CLIENT_ID=your-hubspot-client-id
HUBSPOT_CLIENT_SECRET=your-hubspot-client-secret

# Nango API credentials (OAuth token management)
NANGO_SECRET_KEY=your-nango-secret-key
NANGO_BASE_URL=https://api.nango.dev
NANGO_PROVIDER_CONFIG_KEY=hubspot

# CORS — comma-separated list of allowed origins (empty = no CORS middleware)
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.com
